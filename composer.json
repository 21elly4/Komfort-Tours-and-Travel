{
    "name": "komfort/tours-travel",
    "description": "Komfort Tours & Travel - Professional travel booking platform",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.5",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Komfort\\App\\": "app/",
            "Komfort\\Config\\": "config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Komfort\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs --standard=PSR12 app/",
        "cs-fix": "phpcbf --standard=PSR12 app/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
